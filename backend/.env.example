NODE_ENV=development
PORT=5180

# Session — generate dengan: openssl rand -hex 32
SESSION_SECRET=replace-with-random-32-byte-hex

# PostgreSQL (write — app's own DB)
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=journal_correction
PG_USER=journal_app
PG_PASSWORD=your-postgres-password

# MySQL (read-only — production data lookup)
DB_HOST=your-mysql-host
DB_DATABASE=your-database
DB_USER=your-readonly-user
DB_PASSWORD=your-mysql-password
DB_PORT=3306

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=5
MAX_UPLOAD_FILES=5
